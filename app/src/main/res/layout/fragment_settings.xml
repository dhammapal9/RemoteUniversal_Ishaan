<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingBottom="120dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:paddingTop="@dimen/spacing_lg">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_sm"
            android:layout_marginBottom="@dimen/spacing_md"
            android:text="@string/settings_title"
            android:textColor="?attr/colorOnSurface"
            android:textSize="32sp"
            android:textStyle="bold" />

        <!-- ─── Premium card ─── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/premiumCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="@color/transparent"
            app:cardCornerRadius="@dimen/radius_2xl"
            app:cardElevation="0dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_premium_card" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_xl">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_crown" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:layout_weight="1"
                        android:text="@string/unlock_premium"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="@string/premium_bullet_1"
                    android:textColor="@color/white"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/premium_bullet_2"
                    android:textColor="@color/white"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/premium_bullet_3"
                    android:textColor="@color/white"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_gravity="end"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:background="@drawable/bg_pill_white"
                    android:gravity="center"
                    android:paddingHorizontal="@dimen/spacing_lg"
                    android:text="@string/upgrade_now"
                    android:textAllCaps="false"
                    android:textColor="@color/accent_blue"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ─── APPEARANCE ─── -->
        <TextView
            style="@style/TextAppearance.UniversalRemote.SectionHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_appearance" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.UniversalRemote.SettingsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/themeRow"
                    style="@style/Widget.UniversalRemote.SettingsRow">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_setting_icon_violet">
                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_palette"
                            app:tint="@color/white" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_lg"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView style="@style/TextAppearance.UniversalRemote.SettingsTitle" android:text="@string/settings_theme" />
                        <TextView android:id="@+id/themeValue" style="@style/TextAppearance.UniversalRemote.SettingsValue" android:text="@string/theme_system" />
                    </LinearLayout>

                    <ImageView android:layout_width="18dp" android:layout_height="18dp" android:contentDescription="@null" android:src="@drawable/ic_chevron_right" app:tint="@color/text_tertiary_dark" />
                </LinearLayout>

                <View style="@style/Widget.UniversalRemote.RowDivider" />

                <LinearLayout
                    android:id="@+id/languageRow"
                    style="@style/Widget.UniversalRemote.SettingsRow">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_setting_icon_blue">
                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_globe"
                            app:tint="@color/white" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_lg"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView style="@style/TextAppearance.UniversalRemote.SettingsTitle" android:text="@string/settings_languages" />
                        <TextView android:id="@+id/languageValue" style="@style/TextAppearance.UniversalRemote.SettingsValue" android:text="@string/lang_english" />
                    </LinearLayout>

                    <ImageView android:layout_width="18dp" android:layout_height="18dp" android:contentDescription="@null" android:src="@drawable/ic_chevron_right" app:tint="@color/text_tertiary_dark" />
                </LinearLayout>

                <View style="@style/Widget.UniversalRemote.RowDivider" />

                <LinearLayout style="@style/Widget.UniversalRemote.SettingsRow">
                    <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_setting_icon_orange">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:layout_gravity="center" android:contentDescription="@null" android:src="@drawable/ic_finger" app:tint="@color/white" />
                    </FrameLayout>
                    <TextView style="@style/TextAppearance.UniversalRemote.SettingsTitle" android:layout_width="0dp" android:layout_marginStart="@dimen/spacing_lg" android:layout_weight="1" android:text="@string/settings_haptic" />
                    <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/hapticSwitch" style="@style/Widget.UniversalRemote.Switch" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>

                <View style="@style/Widget.UniversalRemote.RowDivider" />

                <LinearLayout style="@style/Widget.UniversalRemote.SettingsRow">
                    <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_setting_icon_pink">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:layout_gravity="center" android:contentDescription="@null" android:src="@drawable/ic_sparkle" app:tint="@color/white" />
                    </FrameLayout>
                    <TextView style="@style/TextAppearance.UniversalRemote.SettingsTitle" android:layout_width="0dp" android:layout_marginStart="@dimen/spacing_lg" android:layout_weight="1" android:text="@string/settings_animations" />
                    <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/animationsSwitch" style="@style/Widget.UniversalRemote.Switch" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>

                <View style="@style/Widget.UniversalRemote.RowDivider" />

                <LinearLayout style="@style/Widget.UniversalRemote.SettingsRow">
                    <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_setting_icon_green">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:layout_gravity="center" android:contentDescription="@null" android:src="@drawable/ic_volume_up" app:tint="@color/white" />
                    </FrameLayout>
                    <TextView style="@style/TextAppearance.UniversalRemote.SettingsTitle" android:layout_width="0dp" android:layout_marginStart="@dimen/spacing_lg" android:layout_weight="1" android:text="@string/settings_sounds" />
                    <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/soundSwitch" style="@style/Widget.UniversalRemote.Switch" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ─── CONNECTION ─── -->
        <TextView style="@style/TextAppearance.UniversalRemote.SectionHeader" android:text="@string/settings_remote_prefs" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.UniversalRemote.SettingsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout android:id="@+id/reconnectRow" style="@style/Widget.UniversalRemote.SettingsRow">
                    <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_setting_icon_cyan">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:layout_gravity="center" android:contentDescription="@null" android:src="@drawable/ic_link" app:tint="@color/white" />
                    </FrameLayout>
                    <TextView style="@style/TextAppearance.UniversalRemote.SettingsTitle" android:layout_width="0dp" android:layout_marginStart="@dimen/spacing_lg" android:layout_weight="1" android:text="@string/reconnect_to_tv" />
                    <ImageView android:layout_width="18dp" android:layout_height="18dp" android:contentDescription="@null" android:src="@drawable/ic_chevron_right" app:tint="@color/text_tertiary_dark" />
                </LinearLayout>

                <View style="@style/Widget.UniversalRemote.RowDivider" />

                <LinearLayout android:id="@+id/restoreRow" style="@style/Widget.UniversalRemote.SettingsRow">
                    <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_setting_icon_gold">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:layout_gravity="center" android:contentDescription="@null" android:src="@drawable/ic_restore" app:tint="@color/white" />
                    </FrameLayout>
                    <TextView style="@style/TextAppearance.UniversalRemote.SettingsTitle" android:layout_width="0dp" android:layout_marginStart="@dimen/spacing_lg" android:layout_weight="1" android:text="@string/restore_purchases" />
                    <ImageView android:layout_width="18dp" android:layout_height="18dp" android:contentDescription="@null" android:src="@drawable/ic_chevron_right" app:tint="@color/text_tertiary_dark" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ─── SUPPORT ─── -->
        <TextView style="@style/TextAppearance.UniversalRemote.SectionHeader" android:text="@string/settings_about" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.UniversalRemote.SettingsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout android:id="@+id/contactRow" style="@style/Widget.UniversalRemote.SettingsRow">
                    <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_setting_icon_blue">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:layout_gravity="center" android:contentDescription="@null" android:src="@drawable/ic_mail" app:tint="@color/white" />
                    </FrameLayout>
                    <TextView style="@style/TextAppearance.UniversalRemote.SettingsTitle" android:layout_width="0dp" android:layout_marginStart="@dimen/spacing_lg" android:layout_weight="1" android:text="@string/contact_us" />
                    <ImageView android:layout_width="18dp" android:layout_height="18dp" android:contentDescription="@null" android:src="@drawable/ic_chevron_right" app:tint="@color/text_tertiary_dark" />
                </LinearLayout>

                <View style="@style/Widget.UniversalRemote.RowDivider" />

                <LinearLayout android:id="@+id/featureRow" style="@style/Widget.UniversalRemote.SettingsRow">
                    <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_setting_icon_violet">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:layout_gravity="center" android:contentDescription="@null" android:src="@drawable/ic_chat" app:tint="@color/white" />
                    </FrameLayout>
                    <TextView style="@style/TextAppearance.UniversalRemote.SettingsTitle" android:layout_width="0dp" android:layout_marginStart="@dimen/spacing_lg" android:layout_weight="1" android:text="@string/feature_request" />
                    <ImageView android:layout_width="18dp" android:layout_height="18dp" android:contentDescription="@null" android:src="@drawable/ic_chevron_right" app:tint="@color/text_tertiary_dark" />
                </LinearLayout>

                <View style="@style/Widget.UniversalRemote.RowDivider" />

                <LinearLayout android:id="@+id/shareRow" style="@style/Widget.UniversalRemote.SettingsRow">
                    <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_setting_icon_cyan">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:layout_gravity="center" android:contentDescription="@null" android:src="@drawable/ic_share" app:tint="@color/white" />
                    </FrameLayout>
                    <TextView style="@style/TextAppearance.UniversalRemote.SettingsTitle" android:layout_width="0dp" android:layout_marginStart="@dimen/spacing_lg" android:layout_weight="1" android:text="@string/share_app" />
                    <ImageView android:layout_width="18dp" android:layout_height="18dp" android:contentDescription="@null" android:src="@drawable/ic_chevron_right" app:tint="@color/text_tertiary_dark" />
                </LinearLayout>

                <View style="@style/Widget.UniversalRemote.RowDivider" />

                <LinearLayout android:id="@+id/rateRow" style="@style/Widget.UniversalRemote.SettingsRow">
                    <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_setting_icon_gold">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:layout_gravity="center" android:contentDescription="@null" android:src="@drawable/ic_star" app:tint="@color/white" />
                    </FrameLayout>
                    <TextView style="@style/TextAppearance.UniversalRemote.SettingsTitle" android:layout_width="0dp" android:layout_marginStart="@dimen/spacing_lg" android:layout_weight="1" android:text="@string/rate_us" />
                    <ImageView android:layout_width="18dp" android:layout_height="18dp" android:contentDescription="@null" android:src="@drawable/ic_chevron_right" app:tint="@color/text_tertiary_dark" />
                </LinearLayout>

                <View style="@style/Widget.UniversalRemote.RowDivider" />

                <LinearLayout android:id="@+id/privacyRow" style="@style/Widget.UniversalRemote.SettingsRow">
                    <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_setting_icon_green">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:layout_gravity="center" android:contentDescription="@null" android:src="@drawable/ic_shield" app:tint="@color/white" />
                    </FrameLayout>
                    <TextView style="@style/TextAppearance.UniversalRemote.SettingsTitle" android:layout_width="0dp" android:layout_marginStart="@dimen/spacing_lg" android:layout_weight="1" android:text="@string/settings_privacy" />
                    <ImageView android:layout_width="18dp" android:layout_height="18dp" android:contentDescription="@null" android:src="@drawable/ic_chevron_right" app:tint="@color/text_tertiary_dark" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_2xl"
            android:gravity="center"
            android:text="@string/app_name"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/versionLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="v1.0.0"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="12sp"
            tools:ignore="HardcodedText" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
