<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/onboardingFragment"
        android:name="com.idp.universalremote.presentation.onboarding.OnboardingFragment"
        android:label="Onboarding"
        tools:layout="@layout/fragment_onboarding"
        xmlns:tools="http://schemas.android.com/tools">
        <action
            android:id="@+id/action_onboarding_to_home"
            app:destination="@id/wifiPromptFragment"
            app:popUpTo="@id/onboardingFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/wifiPromptFragment"
        android:name="com.idp.universalremote.presentation.wifi.WifiPromptFragment"
        android:label="Connect Wi-Fi"
        tools:layout="@layout/fragment_wifi_prompt"
        xmlns:tools="http://schemas.android.com/tools">
        <action
            android:id="@+id/action_wifi_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/wifiPromptFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_wifi_to_search"
            app:destination="@id/searchDevicesFragment"
            app:popUpTo="@id/wifiPromptFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.idp.universalremote.presentation.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home"
        xmlns:tools="http://schemas.android.com/tools">
        <action
            android:id="@+id/action_home_to_search"
            app:destination="@id/searchDevicesFragment" />
        <action
            android:id="@+id/action_home_to_remote"
            app:destination="@id/remoteFragment" />
        <action
            android:id="@+id/action_home_to_mirroring"
            app:destination="@id/mirroringFragment" />
        <action
            android:id="@+id/action_home_to_cast"
            app:destination="@id/castFragment" />
        <action
            android:id="@+id/action_home_to_settings"
            app:destination="@id/settingsFragment" />
        <action
            android:id="@+id/action_home_to_premium"
            app:destination="@id/premiumFragment" />
    </fragment>

    <fragment
        android:id="@+id/searchDevicesFragment"
        android:name="com.idp.universalremote.presentation.search.SearchDevicesFragment"
        android:label="Search"
        tools:layout="@layout/fragment_search_devices"
        xmlns:tools="http://schemas.android.com/tools">
        <action
            android:id="@+id/action_search_to_remote"
            app:destination="@id/remoteFragment"
            app:popUpTo="@id/searchDevicesFragment"
            app:popUpToInclusive="true">
            <argument
                android:name="deviceId"
                android:defaultValue=""
                app:argType="string" />
        </action>
    </fragment>

    <fragment
        android:id="@+id/remoteFragment"
        android:name="com.idp.universalremote.presentation.remote.RemoteFragment"
        android:label="Remote"
        tools:layout="@layout/fragment_remote"
        xmlns:tools="http://schemas.android.com/tools">
        <argument
            android:name="profile"
            android:defaultValue="default"
            app:argType="string" />
        <action
            android:id="@+id/action_remote_to_settings"
            app:destination="@id/settingsFragment" />
        <action
            android:id="@+id/action_remote_to_premium"
            app:destination="@id/premiumFragment" />
    </fragment>

    <fragment
        android:id="@+id/appsFragment"
        android:name="com.idp.universalremote.presentation.apps.AppsFragment"
        android:label="Apps"
        tools:layout="@layout/fragment_apps"
        xmlns:tools="http://schemas.android.com/tools" />

    <fragment
        android:id="@+id/mirroringFragment"
        android:name="com.idp.universalremote.presentation.mirroring.MirroringFragment"
        android:label="Mirroring"
        tools:layout="@layout/fragment_mirroring"
        xmlns:tools="http://schemas.android.com/tools" />

    <fragment
        android:id="@+id/castFragment"
        android:name="com.idp.universalremote.presentation.cast.CastFragment"
        android:label="Cast"
        tools:layout="@layout/fragment_cast"
        xmlns:tools="http://schemas.android.com/tools">
        <action
            android:id="@+id/action_cast_to_mirroring"
            app:destination="@id/mirroringFragment" />
        <action
            android:id="@+id/action_cast_to_media_picker"
            app:destination="@id/mediaPickerFragment">
            <argument
                android:name="type"
                android:defaultValue="image"
                app:argType="string" />
        </action>
    </fragment>

    <fragment
        android:id="@+id/mediaPickerFragment"
        android:name="com.idp.universalremote.presentation.cast.MediaPickerFragment"
        android:label="Media"
        tools:layout="@layout/fragment_media_picker"
        xmlns:tools="http://schemas.android.com/tools" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.idp.universalremote.presentation.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings"
        xmlns:tools="http://schemas.android.com/tools">
        <action
            android:id="@+id/action_settings_to_premium"
            app:destination="@id/premiumFragment" />
        <action
            android:id="@+id/action_settings_to_search"
            app:destination="@id/searchDevicesFragment" />
    </fragment>

    <fragment
        android:id="@+id/premiumFragment"
        android:name="com.idp.universalremote.presentation.premium.PremiumFragment"
        android:label="Premium"
        tools:layout="@layout/fragment_premium"
        xmlns:tools="http://schemas.android.com/tools" />
</navigation>
